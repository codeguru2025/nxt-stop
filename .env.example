# ─── DATABASE (DigitalOcean Managed PostgreSQL) ──────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@pooler-host:PORT/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@db-host:PORT/DATABASE?sslmode=require"

# ─── AUTH ────────────────────────────────────────────────────────────────────
JWT_SECRET=""

# ─── APP ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://yourdomain.com"
NEXT_PUBLIC_APP_NAME="NXT STOP"

# ─── DO SPACES ───────────────────────────────────────────────────────────────
DO_SPACES_ENDPOINT="https://nyc3.digitaloceanspaces.com"
DO_SPACES_REGION="nyc3"
DO_SPACES_KEY=""
DO_SPACES_SECRET=""
DO_SPACES_BUCKET="nxt-stop"
DO_SPACES_CDN_URL="https://nxt-stop.nyc3.cdn.digitaloceanspaces.com"

# ─── PAYNOW ──────────────────────────────────────────────────────────────────
PAYNOW_INTEGRATION_ID=""
PAYNOW_INTEGRATION_KEY=""

# ─── PLATFORM FEE ────────────────────────────────────────────────────────────
PLATFORM_FEE_PER_TICKET="0.10"

# ─── VALKEY / REDIS ──────────────────────────────────────────────────────────
REDIS_URL="rediss://default:PASSWORD@valkey-host:PORT"
