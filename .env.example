# ─── DATABASE (DigitalOcean Managed PostgreSQL) ──────────────────────────────
# DATABASE_URL  → pooled connection via PgBouncer (port 25061) — used by the app at runtime
# DIRECT_URL    → direct non-pooled connection (port 25060) — used by Prisma migrations
# Both strings from: DO dashboard → Databases → your cluster → Connection Details
DATABASE_URL="postgresql://doadmin:YOUR_PASSWORD@private-your-db-host.db.ondigitalocean.com:25061/defaultdb?sslmode=require"
DIRECT_URL="postgresql://doadmin:YOUR_PASSWORD@private-your-db-host.db.ondigitalocean.com:25060/defaultdb?sslmode=require"

# ─── AUTH ────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-string"

# ─── APP ─────────────────────────────────────────────────────────────────────
# Your DigitalOcean app URL (no trailing slash)
NEXT_PUBLIC_APP_URL="https://your-app.ondigitalocean.app"
NEXT_PUBLIC_APP_NAME="NXT STOP"

# ─── DO SPACES (S3-compatible object storage) ────────────────────────────────
# From Spaces dashboard → Settings → Access Keys
DO_SPACES_ENDPOINT="https://lon1.digitaloceanspaces.com"
DO_SPACES_REGION="lon1"
DO_SPACES_KEY="your-spaces-access-key"
DO_SPACES_SECRET="your-spaces-secret-key"
DO_SPACES_BUCKET="nxt-stop"
DO_SPACES_CDN_URL="https://nxtstop-uploads.lon1.cdn.digitaloceanspaces.com"

# ─── PAYNOW ──────────────────────────────────────────────────────────────────
# From https://www.paynow.co.zw/Account/Merchant → Integration Keys
PAYNOW_INTEGRATION_ID="your-integration-id"
PAYNOW_INTEGRATION_KEY="your-integration-key"
PAYNOW_EMAIL="your-merchant-email@example.com"

# ─── PLATFORM FEE ────────────────────────────────────────────────────────────
# Flat fee in USD added per ticket (0.10 = $0.10 per ticket)
PLATFORM_FEE_PER_TICKET="0.10"

# ─── VALKEY / REDIS ──────────────────────────────────────────────────────────
# From DO Managed Valkey dashboard → Connection Details (use rediss:// for TLS)
REDIS_URL="rediss://default:YOUR_PASSWORD@private-your-valkey-host:25061"

# ─── ADMIN SEED ──────────────────────────────────────────────────────────────
# Phone numbers must be unique and in international format (e.g. +263...)
ADMIN_PHONE_NUMBER="+263..."
ADMIN_PASSWORD="change-me-to-strong-password"
GATE_PHONE="+263..."
GATE_PASSWORD="change-me-to-strong-password"
SEED_SECRET="change-me"

# ─── META / WHATSAPP (optional — leave blank to disable WhatsApp notifications) ─
# From Meta for Developers → Your App → WhatsApp → API Setup
META_WHATSAPP_TOKEN=""
META_WHATSAPP_PHONE_NUMBER_ID=""
META_APP_SECRET=""
# Verify token you choose when registering the webhook in Meta dashboard
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
# Template name and language code configured in Meta Business Manager
WHATSAPP_TEMPLATE_NAME="ticket_confirmation"
WHATSAPP_TEMPLATE_LANG="en"
