# ─── DATABASE (DigitalOcean Managed PostgreSQL) ──────────────────────────────
# Use the PRIVATE connection string from DO database dashboard → Connection Details
# Format: postgresql://USER:PASSWORD@PRIVATE_HOST:PORT/DBNAME?sslmode=require
DATABASE_URL="postgresql://doadmin:YOUR_PASSWORD@private-your-db-host.db.ondigitalocean.com:25060/defaultdb?sslmode=require"

# ─── AUTH ────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-string"

# ─── APP ─────────────────────────────────────────────────────────────────────
# Your DigitalOcean app URL (no trailing slash)
NEXT_PUBLIC_APP_URL="https://your-app.ondigitalocean.app"
NEXT_PUBLIC_APP_NAME="NXT STOP"

# ─── DO SPACES (S3-compatible object storage) ────────────────────────────────
# From Spaces dashboard → Settings → Access Keys
DO_SPACES_ENDPOINT="https://lon1.digitaloceanspaces.com"
DO_SPACES_REGION="lon1"
DO_SPACES_KEY="your-spaces-access-key"
DO_SPACES_SECRET="your-spaces-secret-key"
DO_SPACES_BUCKET="nxt-stop"
DO_SPACES_CDN_URL="https://nxt-stop.lon1.cdn.digitaloceanspaces.com"

# ─── PAYNOW ──────────────────────────────────────────────────────────────────
# From https://www.paynow.co.zw/Account/Merchant → Integration Keys
PAYNOW_INTEGRATION_ID="your-integration-id"
PAYNOW_INTEGRATION_KEY="your-integration-key"

# ─── PLATFORM FEE ────────────────────────────────────────────────────────────
# Flat fee in USD added per ticket (0.10 = $0.10 per ticket)
PLATFORM_FEE_PER_TICKET="0.10"

# ─── VALKEY / REDIS ──────────────────────────────────────────────────────────
# From DO Managed Valkey dashboard → Connection Details (use rediss:// for TLS)
REDIS_URL="rediss://default:YOUR_PASSWORD@private-your-valkey-host:25061"

# ─── ADMIN SEED ──────────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"
GATE_EMAIL="gate@example.com"
GATE_PASSWORD="change-me"
SEED_SECRET="change-me"
