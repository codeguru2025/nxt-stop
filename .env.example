# ─── DATABASE (DigitalOcean Managed PostgreSQL) ──────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@pooler-host:PORT/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@db-host:PORT/DATABASE?sslmode=require"

# ─── AUTH ────────────────────────────────────────────────────────────────────
JWT_SECRET=""

# ─── ADMIN / GATE SEED CREDENTIALS ───────────────────────────────────────────
ADMIN_EMAIL="admin@nxtstop.com"
ADMIN_PASSWORD=""
GATE_EMAIL="gate@nxtstop.com"
