{
  "expo": {
    "name": "NXT STOP Gate",
    "slug": "nxtstop-gate-scanner",
    "version": "1.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "backgroundColor": "#0a0a0a",
      "resizeMode": "contain"
    },
    "android": {
      "package": "com.nxtstop.gate",
      "versionCode": 4,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-splash-screen",
      [
        "expo-camera",
        {
          "cameraPermission": "NXT STOP Gate needs your camera to scan QR tickets."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "e42f8ae4-c35f-4e93-90cc-0c6b046f8b3f"
      }
    }
  }
}
